{
  "name": "@talocode/gatelane",
  "version": "0.2.0",
  "description": "Open-source MCP gateway and agent tool control plane — auth, policies, rate limits, audit logs, discovery, and routing for AI agents.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "bin": {
    "gatelane": "dist/cli.js"
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/cli.js",
    "dist/cli.d.ts",
    "dist/sdk.js",
    "dist/sdk.d.ts",
    "dist/server.js",
    "dist/server.d.ts",
    "dist/mcp-server.js",
    "dist/mcp-server.d.ts",
    "dist/sea-entry.cjs",
    "dist/core",
    "dist/commands",
    "skills",
    "docs",
    "installers",
    "examples",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "node scripts/test.mjs",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/uvu test .test.ts -w",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "demo": "node dist/cli.js demo",
    "doctor": "node dist/cli.js doctor",
    "serve": "node dist/cli.js serve",
    "build:binary": "node scripts/build-binaries.mjs"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "cross-fetch": "^4.0.0",
    "express": "^4.21.0",
    "uuid": "^10.0.0"
  },
  "optionalDependencies": {
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.25.0",
    "postject": "^1.0.0-alpha.6",
    "typescript": "^5.6.0",
    "uvu": "^0.5.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "ai-agents",
    "gateway",
    "agent-tools",
    "api-gateway",
    "talocode",
    "sdk",
    "cli",
    "typescript",
    "open-source"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/talocode/gatelane.git"
  },
  "homepage": "https://github.com/talocode/gatelane",
  "bugs": "https://github.com/talocode/gatelane/issues"
}
